<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="tn.esprit.controllers.NavbarController"
            prefHeight="82.0" prefWidth="1280.0"
            style="-fx-background-color: #000000; -fx-border-color: rgba(255,255,255,0.06); -fx-border-width: 0 0 1 0;">

    <left>
        <HBox alignment="CENTER_LEFT" spacing="12.0" BorderPane.alignment="CENTER">
            <padding><Insets left="36.0" /></padding>
            <VBox spacing="-2.0">
                <Label style="-fx-text-fill: white; -fx-font-size: 17px; -fx-font-weight: bold;" text="ESPORTS" />
                <Label style="-fx-text-fill: #cfd5df; -fx-font-size: 10px;" text="COMMUNITY" />
            </VBox>
        </HBox>
    </left>

    <center>
        <HBox alignment="CENTER" spacing="28.0">
            <Button onAction="#goToHome" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: bold; -fx-cursor: hand;" text="Home" />
            <Button onAction="#goToJeux" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: bold; -fx-cursor: hand;" text="Jeux" />
            <Button onAction="#goToTeam" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: bold; -fx-cursor: hand;" text="Team" />
            <Button onAction="#goToTournement" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: bold; -fx-cursor: hand;" text="Tournoi" />
            <Button onAction="#goToAbout" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: bold; -fx-cursor: hand;" text="Blog" />
            <Button onAction="#goToLive"
                    style="-fx-background-color: transparent; -fx-text-fill: white;
               -fx-font-size: 15px; -fx-font-weight: bold; -fx-cursor: hand;"
                    text="LIVE" />
            <Button onAction="#goToMain" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: bold; -fx-cursor: hand;" text="Products" />
        </HBox>
    </center>

    <right>
        <HBox alignment="CENTER_RIGHT" spacing="16.0" BorderPane.alignment="CENTER">
            <padding><Insets right="34.0" /></padding>
            <Button onAction="#goToCart"
                    style="-fx-background-color: transparent; -fx-text-fill: white;
                       -fx-font-size: 20px; -fx-cursor: hand;"
                    text="🛒" />

            <Button fx:id="profileUserButton" onAction="#goToUser" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: bold; -fx-cursor: hand;" text="Profile User" />
        </HBox>
    </right>

</BorderPane>