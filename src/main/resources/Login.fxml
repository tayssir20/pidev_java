<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Separator?>

<AnchorPane
        xmlns="http://javafx.com/javafx/8"
        xmlns:fx="http://javafx.com/fxml"
        fx:controller="tn.esprit.controllers.LoginController"
        prefHeight="500.0" prefWidth="680.0"
        style="-fx-background-color: #0a0050;">

    <HBox AnchorPane.topAnchor="40" AnchorPane.bottomAnchor="40"
          AnchorPane.leftAnchor="60" AnchorPane.rightAnchor="60"
          style="-fx-background-color: white; -fx-background-radius: 6;">

        <ImageView fitWidth="280" fitHeight="420" preserveRatio="false">
            <image>
                <Image url="https://i.pinimg.com/736x/29/bf/08/29bf083bd37ae14f65bb683caf2e3096.jpg"/>
            </image>
        </ImageView>

        <VBox spacing="14" alignment="TOP_LEFT"
              style="-fx-padding: 40 38 36 38; -fx-background-color: white;">

            <Label text="Login Form"
                   style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #111;"/>

            <Region prefWidth="26" prefHeight="4"
                    style="-fx-background-color: #E6C819; -fx-background-radius: 2;"/>

            <!-- Email Field -->
            <VBox spacing="4">
                <Label text="Email"
                       style="-fx-font-size: 11px; -fx-text-fill: #777;"/>
                <TextField fx:id="usernameField" promptText="Enter your email"
                           style="-fx-background-color: transparent; -fx-border-color: transparent transparent #bbb transparent; -fx-border-width: 0 0 1.5 0; -fx-padding: 6 0; -fx-font-size: 14px;"/>
                <Label fx:id="emailError" text="" visible="false" managed="false"
                       style="-fx-font-size: 11px; -fx-text-fill: red; -fx-padding: 4 0 0 0;"/>
            </VBox>

            <!-- Password Field -->
            <VBox spacing="4">
                <Label text="Password"
                       style="-fx-font-size: 11px; -fx-text-fill: #777;"/>
                <PasswordField fx:id="passwordField" promptText="Enter your password"
                               style="-fx-background-color: transparent; -fx-border-color: transparent transparent #bbb transparent; -fx-border-width: 0 0 1.5 0; -fx-padding: 6 0; -fx-font-size: 14px;"/>
                <Label fx:id="passwordError" text="" visible="false" managed="false"
                       style="-fx-font-size: 11px; -fx-text-fill: red; -fx-padding: 4 0 0 0;"/>
            </VBox>

            <!-- Login Button -->
            <Button fx:id="loginButton" text="Login"
                    maxWidth="Infinity" onAction="#handleLogin"
                    style="-fx-background-color: #5b4cdf; -fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: bold; -fx-background-radius: 5; -fx-padding: 11 0; -fx-cursor: hand;"/>

            <!-- Register + Forgot Password Links -->
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Hyperlink text="Create an account" onAction="#goToRegister"
                           style="-fx-text-fill: #5b4cdf; -fx-font-size: 12px; -fx-border-color: transparent; -fx-padding: 0;"/>
                <Label text="|" style="-fx-text-fill: #bbb; -fx-font-size: 12px;"/>
                <Hyperlink text="Forgot your password?" onAction="#handleForgotPassword"
                           style="-fx-text-fill: #5b4cdf; -fx-font-size: 12px; -fx-border-color: transparent; -fx-padding: 0;"/>
            </HBox>

            <!-- Divider -->
            <HBox alignment="CENTER" spacing="10">
                <Separator HBox.hgrow="ALWAYS"/>
                <Label text="Or sign in with:"
                       style="-fx-font-size: 12px; -fx-text-fill: #888;"/>
                <Separator HBox.hgrow="ALWAYS"/>
            </HBox>

            <!-- Sign in with Google -->
            <Button text="G   Sign in with Google"
                    maxWidth="Infinity" onAction="#handleGoogleSignUp"
                    style="-fx-background-color: #333; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 5; -fx-padding: 11 0; -fx-cursor: hand;"/>

            <!-- Sign in with Face Recognition -->
            <Button text="  Sign in with Face Recognition"
                    maxWidth="Infinity" onAction="#handleFaceRecognition"
                    style="-fx-background-color: #5b4cdf; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 5; -fx-padding: 11 0; -fx-cursor: hand;"/>

            <Label fx:id="messageLabel" text=""
                   style="-fx-font-size: 12px; -fx-wrap-text: true;"/>
        </VBox>
    </HBox>
</AnchorPane>