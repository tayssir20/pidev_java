<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns="http://javafx.com/javafx/8"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="tn.esprit.controllers.ResetPasswordController"
            prefHeight="500.0" prefWidth="540.0"
            style="-fx-background-color: #0a0050;">

    <VBox spacing="14" alignment="TOP_LEFT"
          AnchorPane.topAnchor="38.0" AnchorPane.bottomAnchor="38.0"
          AnchorPane.leftAnchor="55.0" AnchorPane.rightAnchor="55.0"
          style="-fx-padding: 36; -fx-background-color: white; -fx-background-radius: 6;">

        <Label text="Reset Password"
               style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #111;"/>

        <Region prefWidth="26" prefHeight="4"
                style="-fx-background-color: #E6C819; -fx-background-radius: 2;"/>

        <Label text="Email"
               style="-fx-font-size: 11px; -fx-text-fill: #777;"/>
        <Label fx:id="emailLabel" text=""
               style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #5b4cdf;"/>

        <VBox spacing="4">
            <Label text="Reset code"
                   style="-fx-font-size: 11px; -fx-text-fill: #777;"/>
            <TextField fx:id="codeField" promptText="Enter the 6-digit code"
                       style="-fx-background-color: transparent; -fx-border-color: transparent transparent #bbb transparent; -fx-border-width: 0 0 1.5 0; -fx-padding: 6 0; -fx-font-size: 14px;"/>
            <Label fx:id="codeError" text="" visible="false" managed="false"
                   style="-fx-font-size: 11px; -fx-text-fill: red;"/>
        </VBox>

        <VBox spacing="4">
            <Label text="New password"
                   style="-fx-font-size: 11px; -fx-text-fill: #777;"/>
            <PasswordField fx:id="newPasswordField" promptText="Enter your new password"
                           style="-fx-background-color: transparent; -fx-border-color: transparent transparent #bbb transparent; -fx-border-width: 0 0 1.5 0; -fx-padding: 6 0; -fx-font-size: 14px;"/>
            <Label fx:id="newPasswordError" text="" visible="false" managed="false"
                   style="-fx-font-size: 11px; -fx-text-fill: red;"/>
        </VBox>

        <VBox spacing="4">
            <Label text="Confirm new password"
                   style="-fx-font-size: 11px; -fx-text-fill: #777;"/>
            <PasswordField fx:id="confirmPasswordField" promptText="Confirm your new password"
                           style="-fx-background-color: transparent; -fx-border-color: transparent transparent #bbb transparent; -fx-border-width: 0 0 1.5 0; -fx-padding: 6 0; -fx-font-size: 14px;"/>
            <Label fx:id="confirmPasswordError" text="" visible="false" managed="false"
                   style="-fx-font-size: 11px; -fx-text-fill: red;"/>
        </VBox>

        <Button fx:id="resetPasswordButton" text="Reset password"
                maxWidth="Infinity" onAction="#handleResetPassword"
                style="-fx-background-color: #5b4cdf; -fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: bold; -fx-background-radius: 5; -fx-padding: 11 0; -fx-cursor: hand;"/>

        <Button text="Back to login"
                maxWidth="Infinity" onAction="#goToLogin"
                style="-fx-background-color: #333; -fx-text-fill: white; -fx-font-size: 14px; -fx-background-radius: 5; -fx-padding: 11 0; -fx-cursor: hand;"/>

        <Label fx:id="messageLabel" text=""
               style="-fx-font-size: 12px; -fx-wrap-text: true;"/>
    </VBox>
</AnchorPane>
