<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="tn.esprit.controllers.AjouterProduitController"
            prefHeight="550.0" prefWidth="500.0"
            style="-fx-background-color: #0f172a;">

    <VBox spacing="12"
          AnchorPane.topAnchor="30" AnchorPane.leftAnchor="40"
          AnchorPane.rightAnchor="40" AnchorPane.bottomAnchor="30">

        <Label fx:id="titleLabel" text="➕ Ajouter un Produit"
               style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: white;"/>

        <!-- Nom -->
        <Label text="Nom" style="-fx-text-fill: #94a3b8;"/>
        <TextField fx:id="nameField" promptText="Ex: Keyboard MSI"
                   style="-fx-background-color: #1e293b; -fx-text-fill: white;
                          -fx-pref-height: 38px;"/>

        <!-- Description -->
        <Label text="Description" style="-fx-text-fill: #94a3b8;"/>
        <TextField fx:id="descriptionField" promptText="Ex: RGB Mechanical"
                   style="-fx-background-color: #1e293b; -fx-text-fill: white;
                          -fx-pref-height: 38px;"/>

        <!-- Prix + Stock -->
        <HBox spacing="15">
            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label text="Prix (TND)" style="-fx-text-fill: #94a3b8;"/>
                <TextField fx:id="priceField" promptText="100.00"
                           style="-fx-background-color: #1e293b; -fx-text-fill: white;
                                  -fx-pref-height: 38px;"/>
            </VBox>
            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label text="Stock" style="-fx-text-fill: #94a3b8;"/>
                <TextField fx:id="stockField" promptText="10"
                           style="-fx-background-color: #1e293b; -fx-text-fill: white;
                                  -fx-pref-height: 38px;"/>
            </VBox>
        </HBox>

        <!-- Image -->
        <Label text="Image" style="-fx-text-fill: #94a3b8;"/>
        <HBox spacing="10">
            <TextField fx:id="imageField" promptText="Choisir une image..."
                       HBox.hgrow="ALWAYS" editable="false"
                       style="-fx-background-color: #1e293b; -fx-text-fill: white;
                              -fx-pref-height: 38px;"/>
            <Button text="📁 Parcourir" onAction="#handleChooseImage"
                    style="-fx-background-color: #334155; -fx-text-fill: white;
                           -fx-pref-height: 38px; -fx-cursor: hand;
                           -fx-background-radius: 8;"/>
        </HBox>

        <!-- Preview image -->
        <ImageView fx:id="imagePreview" fitWidth="150" fitHeight="100"
                   preserveRatio="true" visible="false"/>

        <!-- Catégorie -->
        <Label text="Catégorie" style="-fx-text-fill: #94a3b8;"/>
        <ComboBox fx:id="categoryCombo" maxWidth="Infinity"
                  style="-fx-background-color: #1e293b; -fx-pref-height: 38px;"/>

        <!-- Message -->
        <Label fx:id="messageLabel" text="" style="-fx-font-size: 13px;"/>

        <!-- Boutons -->
        <HBox spacing="10" alignment="CENTER_RIGHT">
            <Button text="Annuler" onAction="#handleCancel"
                    style="-fx-background-color: #e74c3c; -fx-text-fill: white;
                           -fx-pref-width: 110px; -fx-pref-height: 38px;
                           -fx-cursor: hand; -fx-background-radius: 8;"/>
            <Button fx:id="submitBtn" text="✅ Ajouter" onAction="#handleSubmit"
                    style="-fx-background-color: #7c3aed; -fx-text-fill: white;
                           -fx-pref-width: 110px; -fx-pref-height: 38px;
                           -fx-cursor: hand; -fx-background-radius: 8;"/>
        </HBox>

    </VBox>
</AnchorPane>