<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<?import javafx.collections.FXCollections?>
<?import java.lang.String?>
<AnchorPane
        xmlns="http://javafx.com/javafx/8"
        xmlns:fx="http://javafx.com/fxml"
        fx:controller="tn.esprit.controllers.RegisterController"
        prefHeight="500.0" prefWidth="760.0"
        style="-fx-background-color: #0a0050;">

    <HBox AnchorPane.topAnchor="30" AnchorPane.bottomAnchor="30"
          AnchorPane.leftAnchor="50" AnchorPane.rightAnchor="50"
          style="-fx-background-color: white; -fx-background-radius: 6;">

        <ImageView fitWidth="300" fitHeight="440" preserveRatio="false">
            <image>
                <Image url="https://i.pinimg.com/736x/29/bf/08/29bf083bd37ae14f65bb683caf2e3096.jpg"/>
            </image>
        </ImageView>

        <VBox spacing="14" alignment="TOP_LEFT"
              style="-fx-padding: 40 36 36 36; -fx-background-color: white;">

            <Label text="Create Account"
                   style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #111;"/>

            <Region prefWidth="26" prefHeight="4"
                    style="-fx-background-color: #E6C819; -fx-background-radius: 2;"/>

            <!-- Full Name -->
            <VBox spacing="4">
                <Label text="Full Name"
                       style="-fx-font-size: 11px; -fx-text-fill: #777;"/>
                <TextField fx:id="nomField" promptText="Enter your full name"
                           style="-fx-background-color: transparent; -fx-border-color: transparent transparent #bbb transparent; -fx-border-width: 0 0 1.5 0; -fx-padding: 6 0; -fx-font-size: 14px;"/>
                <Label fx:id="nomError" text="" visible="false" managed="false"
                       style="-fx-font-size: 11px; -fx-text-fill: red; -fx-padding: 4 0 0 0;"/>
            </VBox>

            <!-- Email -->
            <VBox spacing="4">
                <Label text="Email"
                       style="-fx-font-size: 11px; -fx-text-fill: #777;"/>
                <TextField fx:id="emailField" promptText="Enter your email"
                           style="-fx-background-color: transparent; -fx-border-color: transparent transparent #bbb transparent; -fx-border-width: 0 0 1.5 0; -fx-padding: 6 0; -fx-font-size: 14px;"/>
                <Label fx:id="emailError" text="" visible="false" managed="false"
                       style="-fx-font-size: 11px; -fx-text-fill: red; -fx-padding: 4 0 0 0;"/>
            </VBox>

            <!-- Role -->
<!--            <VBox spacing="4">-->
<!--                <Label text="Role"-->
<!--                       style="-fx-font-size: 11px; -fx-text-fill: #777;"/>-->
<!--                <ComboBox fx:id="roleComboBox"-->
<!--                          maxWidth="Infinity"-->
<!--                          value="Utilisateur"-->
<!--                          style="-fx-background-color: transparent; -fx-border-color: transparent transparent #bbb transparent; -fx-border-width: 0 0 1.5 0; -fx-font-size: 14px;">-->
<!--                    <items>-->
<!--                        <FXCollections fx:factory="observableArrayList">-->
<!--                            <String fx:value="Utilisateur"/>-->
<!--                            <String fx:value="Admin"/>-->
<!--                        </FXCollections>-->
<!--                    </items>-->
<!--                </ComboBox>-->
<!--            </VBox>-->

            <!-- Password -->
            <VBox spacing="4">
                <Label text="Password"
                       style="-fx-font-size: 11px; -fx-text-fill: #777;"/>
                <PasswordField fx:id="passwordField" promptText="Choose a password"
                               style="-fx-background-color: transparent; -fx-border-color: transparent transparent #bbb transparent; -fx-border-width: 0 0 1.5 0; -fx-padding: 6 0; -fx-font-size: 14px;"/>
                <Label fx:id="passwordError" text="" visible="false" managed="false"
                       style="-fx-font-size: 11px; -fx-text-fill: red; -fx-padding: 4 0 0 0;"/>
            </VBox>

            <!-- Confirm Password -->
            <VBox spacing="4">
                <Label text="Confirm Password"
                       style="-fx-font-size: 11px; -fx-text-fill: #777;"/>
                <PasswordField fx:id="confirmPasswordField" promptText="Repeat your password"
                               style="-fx-background-color: transparent; -fx-border-color: transparent transparent #bbb transparent; -fx-border-width: 0 0 1.5 0; -fx-padding: 6 0; -fx-font-size: 14px;"/>
                <Label fx:id="confirmPasswordError" text="" visible="false" managed="false"
                       style="-fx-font-size: 11px; -fx-text-fill: red; -fx-padding: 4 0 0 0;"/>
            </VBox>

            <!-- Register Button -->
            <Button fx:id="registerButton" text="Register"
                    maxWidth="Infinity" onAction="#handleRegister"
                    style="-fx-background-color: #5b4cdf; -fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: bold; -fx-background-radius: 5; -fx-padding: 11 0; -fx-cursor: hand;"/>

            <!-- Already have an account -->
            <Hyperlink text="Already have an account" onAction="#goToLogin"
                       style="-fx-text-fill: #5b4cdf; -fx-font-size: 12px; -fx-border-color: transparent; -fx-padding: 0;"/>

            <!-- Divider -->
            <HBox alignment="CENTER" spacing="10">
                <Separator HBox.hgrow="ALWAYS"/>
                <Label text="Or sign up with:"
                       style="-fx-font-size: 12px; -fx-text-fill: #888;"/>
                <Separator HBox.hgrow="ALWAYS"/>
            </HBox>

            <!-- Sign up with Google -->
            <Button text="G   Sign up with Google"
                    maxWidth="Infinity" onAction="#handleGoogleSignUp"
                    style="-fx-background-color: #4285f4; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 5; -fx-padding: 13 0; -fx-cursor: hand;"/>

            <!-- Message Label (single, no duplicate) -->
            <Label fx:id="messageLabel" text=""
                   style="-fx-font-size: 12px; -fx-wrap-text: true;"/>

        </VBox>
    </HBox>
</AnchorPane>