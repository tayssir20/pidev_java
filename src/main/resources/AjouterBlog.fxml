<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="tn.esprit.controllers.AjouterBlogController"
            prefHeight="580.0" prefWidth="500.0"
            style="-fx-background-color: #0f172a;">

    <VBox spacing="6"
          AnchorPane.topAnchor="30" AnchorPane.leftAnchor="40"
          AnchorPane.rightAnchor="40" AnchorPane.bottomAnchor="30">

        <Label fx:id="titleLabel" text="➕ Ajouter un Blog"
               style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: white;"/>


        <Label text="Titre" style="-fx-text-fill: #94a3b8;"/>
        <TextField fx:id="titleField" promptText="Ex: Mon premier blog"
                   style="-fx-background-color: #1e293b; -fx-text-fill: white;
                          -fx-pref-height: 38px;"/>
        <Label fx:id="titleError" text=""
               style="-fx-text-fill: #f87171; -fx-font-size: 11px;"
               visible="false" managed="false"/>


        <Label text="Description" style="-fx-text-fill: #94a3b8;"/>
        <TextArea fx:id="categoryField"
                  promptText="Ex: Ceci est la description du blog..."
                  style="-fx-background-color: #1e293b; -fx-text-fill: white;
                         -fx-pref-height: 80px;" wrapText="true"/>
        <Label fx:id="categoryError" text=""
               style="-fx-text-fill: #f87171; -fx-font-size: 11px;"
               visible="false" managed="false"/>


        <Label text="Image" style="-fx-text-fill: #94a3b8;"/>
        <HBox spacing="10">
            <TextField fx:id="contentField" promptText="Choisir une image..."
                       HBox.hgrow="ALWAYS" editable="false"
                       style="-fx-background-color: #1e293b; -fx-text-fill: white;
                              -fx-pref-height: 38px;"/>
            <Button text="📁 Parcourir" onAction="#handleChooseImage"
                    style="-fx-background-color: #334155; -fx-text-fill: white;
                           -fx-pref-height: 38px; -fx-cursor: hand;
                           -fx-background-radius: 8;"/>
        </HBox>
        <Label fx:id="contentError" text=""
               style="-fx-text-fill: #f87171; -fx-font-size: 11px;"
               visible="false" managed="false"/>


        <ImageView fx:id="imagePreview" fitWidth="150" fitHeight="100"
                   preserveRatio="true" visible="false"/>


        <Label fx:id="messageLabel" text="" style="-fx-font-size: 13px;"/>


        <HBox spacing="10" alignment="CENTER_RIGHT">
            <Button text="Annuler" onAction="#handleCancel"
                    style="-fx-background-color: #e74c3c; -fx-text-fill: white;
                           -fx-pref-width: 110px; -fx-pref-height: 38px;
                           -fx-cursor: hand; -fx-background-radius: 8;"/>
            <Button fx:id="submitBtn" text="✅ Ajouter" onAction="#handleSubmit"
                    style="-fx-background-color: #7c3aed; -fx-text-fill: white;
                           -fx-pref-width: 110px; -fx-pref-height: 38px;
                           -fx-cursor: hand; -fx-background-radius: 8;"/>
        </HBox>

    </VBox>
</AnchorPane>