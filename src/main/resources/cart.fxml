<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="tn.esprit.controllers.CartController"
      style="-fx-background-color: #0a0a0a;"
      spacing="0">

    <fx:include source="/Navbar.fxml"/>

    <HBox spacing="30" VBox.vgrow="ALWAYS" style="-fx-padding: 40;">

        <!-- LEFT - Cart Items -->
        <ScrollPane fitToWidth="true" HBox.hgrow="ALWAYS"
                    style="-fx-background: transparent; -fx-background-color: transparent;">
            <VBox fx:id="cartItemsBox" spacing="15"/>
        </ScrollPane>

        <!-- RIGHT - Order Summary -->
        <VBox spacing="20" prefWidth="300" minWidth="280"
              style="-fx-background-color: #1a1a1a; -fx-background-radius: 12; -fx-padding: 25;">

            <Label text="Order Summary"
                   style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;"/>

            <HBox>
                <Label text="Subtotal" style="-fx-text-fill: #888; -fx-font-size: 14px;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="subtotalLabel" text="0.00 TND"
                       style="-fx-text-fill: white; -fx-font-size: 14px;"/>
            </HBox>

            <Separator/>

            <HBox>
                <Label text="Total"
                       style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="totalLabel" text="0.00 TND"
                       style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>
            </HBox>

            <Button text="Checkout" onAction="#handleOrder" maxWidth="Infinity"
                    style="-fx-background-color: black; -fx-text-fill: white;
                           -fx-font-size: 15px; -fx-font-weight: bold;
                           -fx-pref-height: 45px; -fx-background-radius: 8;
                           -fx-cursor: hand; -fx-border-color: #444;
                           -fx-border-radius: 8; -fx-border-width: 1;"/>

            <Button text="Clear Cart" onAction="#handleClearCart" maxWidth="Infinity"
                    style="-fx-background-color: #e53935; -fx-text-fill: white;
                           -fx-font-size: 15px; -fx-font-weight: bold;
                           -fx-pref-height: 45px; -fx-background-radius: 8;
                           -fx-cursor: hand;"/>
        </VBox>

    </HBox>
</VBox>